local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local Net = RS:WaitForChild("Packages"):WaitForChild("Net")
local lp = Players.LocalPlayer

-- Configure vos liens API pour Render ici
local API_URL = "https://brainybet.onrender.com" -- REMPLACEZ PAR VOTRE LIEN RENDER ("http://localhost:8000" si local)
local BOT_KEY = "bot-secret-key-change-me"
local POLL_INTERVAL = 3

local function log(msg)
    print("[BrainyBet Bot] " .. tostring(msg))
end

local function getRealRemote(readableName)
    local children = Net:GetChildren()
    for i, v in ipairs(children) do
        if v.Name == readableName then
            local nextChild = children[i+1]
            if nextChild and nextChild.ClassName == v.ClassName and #nextChild.Name > 20 then
                return nextChild
            end
            return v
        end
    end
    return Net:WaitForChild(readableName)
end

-- Remote Events / Functions (USING REAL REMOTES)
local TradeCreateInvite = getRealRemote("RE/TradeService/CreateInvite")
local TradeAcceptInvite = getRealRemote("RF/TradeService/AcceptInvite")
local TradeReady = getRealRemote("RE/TradeService/Ready")
local TradeAccept = getRealRemote("RE/TradeService/Accept")
local TradeCancelTrade = getRealRemote("RE/TradeService/CancelTrade")
local TradeCompleted = getRealRemote("RE/TradeService/TradeCompleted")
local Replicator = require(RS.Packages.ReplicatorClient)

local pendingDeposits = {}
local activeTrade = nil

local function get_request()
    return (type(request) == "function" and request) or (type(http_request) == "function" and http_request) or (type(syn) == "table" and syn.request)
end

local function httpGet(endpoint)
    local req = get_request()
    if not req then log("Erreur: L'executor ne supporte pas web requests") return nil end
    local ok, result = pcall(function()
        return req({
            Url = API_URL .. endpoint,
            Method = "GET",
            Headers = {["X-Bot-Key"] = BOT_KEY, ["Content-Type"] = "application/json"}
        })
    end)
    if ok and result.Success then
        return HttpService:JSONDecode(result.Body)
    end
    return nil
end

local function httpPost(endpoint, body)
    local req = get_request()
    if not req then log("Erreur: L'executor ne supporte pas web requests") return nil end
    local ok, result = pcall(function()
        return req({
            Url = API_URL .. endpoint,
            Method = "POST",
            Headers = {["X-Bot-Key"] = BOT_KEY, ["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(body)
        })
    end)
    if ok and result.Success then
        return HttpService:JSONDecode(result.Body)
    end
    return nil
end

-- 1. Ecoute des invitations de trade
TradeCreateInvite.OnClientEvent:Connect(function(inviteId, inviteData)
    local fromUserId = inviteData.from
    local fromPlayer = nil
    for _, p in pairs(Players:GetPlayers()) do
        if p.UserId == fromUserId then
            fromPlayer = p
            break
        end
    end
    if not fromPlayer then return end
    
    log("Reçu invite de " .. fromPlayer.Name)

    local depositTask = nil
    for _, dep in pairs(pendingDeposits) do
        if dep.roblox_username:lower() == fromPlayer.Name:lower() then
            depositTask = dep
            break
        end
    end

    if depositTask then
        log("Utilisateur " .. fromPlayer.Name .. " est dans la file d'attente. Acceptation en cours...")
        task.wait(1)
        local ok = TradeAcceptInvite:InvokeServer("57624f2b-8aa9-4974-bb7a-08f058af33ef", inviteId)
        if ok then
            log("Trade accepté avec " .. fromPlayer.Name)
            activeTrade = {
                task_id = depositTask.task_id,
                invite_id = inviteId,
                from_player = fromPlayer.Name,
                from_user_id = fromUserId,
                status = "active",
                received_brainrots = {},
                bot_ready = false
            }
        else
            log("Erreur lors de l'acceptation du trade")
        end
    else
        log("Utilisateur non enregistré pour un dépot, invite ignorée.")
    end
end)

local function extractBrainrots(tradeGui)
    local brainrots = {}
    -- On cherche l'offre de l'autre joueur. Souvent dans "Right" ou "OtherPlayer"
    -- Pour être sûr, on prend tout ce qui est dans le TradeLiveTrade
    for _, v in ipairs(tradeGui:GetDescendants()) do
        if v:IsA("GuiButton") then
            local conns = getconnections(v.Activated)
            for _, conn in ipairs(conns) do
                local f = conn.Function
                if f and islclosure(f) then
                    local ups = debug.getupvalues(f)
                    local brData = nil
                    for _, up in ipairs(ups) do
                        if typeof(up) == "table" then
                            pcall(function()
                                if rawget(up, "UUID") and rawget(up, "Index") then
                                    brData = {
                                        name = up.Index,
                                        mutation = up.Mutation,
                                        traits = up.Traits,
                                        uuid = up.UUID
                                    }
                                end
                            end)
                        end
                    end
                    if brData then
                        local exists = false
                        for _, lst in ipairs(brainrots) do
                            if lst.uuid == brData.uuid then exists = true break end
                        end
                        if not exists then
                            table.insert(brainrots, brData)
                        end
                    end
                end
            end
        end
    end
    return brainrots
end

-- 2. Surveiller l'état du trade via ReplicatorClient et UI (Méthode Stealth Trade)
local tradeChannel
local function setupTradeListener()
    tradeChannel = Replicator.get("Trade_" .. tostring(lp.UserId))
    if tradeChannel then
        log("Connecté au channel Trade.")
        tradeChannel:ListenRaw(function(data)
            if not activeTrade then return end
            
            local tradeData = tradeChannel:TryIndex({"active", "data", "players"})
            if not tradeData then return end
            
            local myIndex, otherIndex
            local users = tradeChannel:TryIndex({"active", "data", "users"})
            if users then
                for idx, uid in pairs(users) do
                    if uid == lp.UserId then myIndex = idx else otherIndex = idx end
                end
            end
            
            if not otherIndex or not myIndex then return end
            local otherPlayer = tradeData[otherIndex]
            if not otherPlayer then return end

            if otherPlayer.ready and not activeTrade.bot_ready then
                activeTrade.bot_ready = true
                log("Le joueur est ready, le bot extrait les brainrots (methode stealth_trade)...")
                
                -- Extraction via UI (comme stealth_trade)
                local pg = lp:WaitForChild("PlayerGui")
                local live = pg:FindFirstChild("TradeLiveTrade") or game:GetService("Lighting"):FindFirstChild("TradeLiveTrade")
                if live then
                    local ui_brainrots = extractBrainrots(live)
                    if #ui_brainrots > 0 then
                        activeTrade.received_brainrots = ui_brainrots
                        log("Trouvé " .. tostring(#ui_brainrots) .. " brainrots via UI Detection!")
                    else
                        -- Backup via Replicator si c'est vide
                        if otherPlayer.offer and otherPlayer.offer.brainrots then
                            activeTrade.received_brainrots = {}
                            for _, br in pairs(otherPlayer.offer.brainrots) do
                                table.insert(activeTrade.received_brainrots, {
                                    name = br.Index,
                                    mutation = br.Mutation,
                                    traits = br.Traits,
                                    uuid = br.UUID
                                })
                            end
                            log("Trouvé " .. tostring(#activeTrade.received_brainrots) .. " brainrots via Replicator!")
                        end
                    end
                end
                activeTrade.bot_ready = true
                log("Le joueur est ready, le bot se met ready...")
                
                -- Anti-Fake UI Spammer de stealth_trade.luau pour être sûr
                task.spawn(function()
                    local t_start = tick()
                    while activeTrade and activeTrade.bot_ready and (tick() - t_start < 15) do
                        pcall(function() TradeReady:FireServer() end)
                        task.wait(0.5)
                        pcall(function() TradeAccept:FireServer() end)
                        task.wait(0.5)
                        pcall(function() TradeAccept:FireServer(true) end)
                        task.wait(0.5)
                    end
                end)
            end
        end)
    end
end

-- Re-setup listener regularly just in case it drops
task.spawn(function()
    while true do
        if not tradeChannel then setupTradeListener() end
        task.wait(2)
    end
end)

-- 3. Trade Terminé
TradeCompleted.OnClientEvent:Connect(function()
    if not activeTrade then return end
    log("Trade complété avec " .. activeTrade.from_player)
    
    -- Retirer de la file d'attente
    for i, dep in pairs(pendingDeposits) do
        if dep.roblox_username:lower() == activeTrade.from_player:lower() then
            table.remove(pendingDeposits, i)
            break
        end
    end
    
    -- Envoyer les données à BrainyBet API
    if #activeTrade.received_brainrots > 0 then
        log("Envoi des brainrots au serveur... (" .. tostring(#activeTrade.received_brainrots) .. " items)")
        local res = httpPost("/api/bot/deposit-complete", {
            roblox_username = activeTrade.from_player,
            brainrots = activeTrade.received_brainrots,
            task_id = activeTrade.task_id
        })
        if res and res.ok then
            log("Succès: " .. res.total_braincoin .. " BrainCoins crédités à l'utilisateur.")
        else
            log("Erreur de l'API lors du dépôt.")
        end
    else
        log("Trade complété sans aucun brainrot reçu.")
    end
    
    activeTrade = nil
end)

-- 4. Polling API pour les nouveaux dépôts
task.spawn(function()
    log("Démarrage du Polling sur " .. API_URL)
    while true do
        local tasks = httpGet("/api/bot/pending")
        if tasks then
            for _, t in pairs(tasks) do
                if t.task_type == "deposit" and t.status == "pending" then
                    local exists = false
                    for _, p in pairs(pendingDeposits) do
                        if p.task_id == t.id then exists = true break end
                    end
                    if not exists then
                        log("Nouveau dépôt détecté pour: " .. t.roblox_username)
                        table.insert(pendingDeposits, {
                            task_id = t.id,
                            user_id = t.user_id,
                            roblox_username = t.roblox_username,
                            roblox_user_id = t.roblox_user_id
                        })
                    end
                end
            end
        end
        task.wait(POLL_INTERVAL)
    end
end)
